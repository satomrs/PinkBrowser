<Window x:Class="VideoThumbnailBrowser.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="140" Width="380" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#252526">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" x:Name="PromptText" Foreground="White" Margin="0,0,0,8" />
        <TextBox Grid.Row="1" x:Name="InputBox" Padding="6,4" Background="#3C3C3C"
                 Foreground="White" BorderBrush="#555" Margin="0,0,0,12" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,8,0" Padding="4"
                    IsDefault="True" Click="OnOkClick" />
            <Button Content="キャンセル" Width="80" Padding="4" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
