<UserControl x:Class="VideoThumbnailBrowser.Controls.ScrubThumbnailControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             MouseEnter="OnMouseEnter"
             MouseMove="OnMouseMove"
             MouseLeave="OnMouseLeave"
             MouseLeftButtonUp="OnMouseLeftButtonUp"
             MouseDoubleClick="OnMouseDoubleClick">
    <UserControl.ContextMenu>
        <ContextMenu Opened="OnContextMenuOpened">
            <MenuItem Header="再生（ソフト1）" Click="OnOpenApp1Click"/>
            <MenuItem x:Name="OpenApp2Item" Header="ソフト2で開く" Click="OnOpenApp2Click" Visibility="Collapsed"/>
            <MenuItem x:Name="OpenApp3Item" Header="ソフト3で開く" Click="OnOpenApp3Click" Visibility="Collapsed"/>
            <MenuItem Header="既定のアプリで開く" Click="OnOpenDefaultClick"/>
            <Separator/>
            <MenuItem Header="フォルダーを開く" Click="OnShowInExplorerClick"/>
            <MenuItem Header="ファイル名をコピー" Click="OnCopyFileNameClick"/>
            <MenuItem Header="フルパスをコピー" Click="OnCopyPathClick"/>
            <Separator/>
            <MenuItem Header="タグを編集..." Click="OnEditTagsClick"/>
            <Separator/>
            <MenuItem Header="ファイルを削除（ごみ箱へ）" Foreground="#FF6666" Click="OnDeleteFileClick"/>
        </ContextMenu>
    </UserControl.ContextMenu>

    <Border x:Name="OuterBorder" BorderThickness="3" CornerRadius="4" BorderBrush="Transparent">
        <Border Background="#1E1E1E" BorderBrush="#3A3A3A" BorderThickness="1"
                CornerRadius="2" ClipToBounds="True">
            <Grid>
                <Image x:Name="ThumbImage" Stretch="UniformToFill"/>

                <!-- 書庫アイコン（書庫ファイルのみ） -->
                <Border x:Name="ArchiveBadge" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Background="#CC884400" CornerRadius="2" Margin="4" Padding="4,1"
                        Visibility="Collapsed">
                    <TextBlock Text="📦" FontSize="11"/>
                </Border>

                <Border VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                        Background="#CC000000" Padding="4,3">
                    <StackPanel>
                        <TextBlock x:Name="FileNameText" Foreground="White" FontSize="11"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="TagsText" Foreground="#AAAAFF" FontSize="10"
                                   TextTrimming="CharacterEllipsis" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                        Background="#CC000000" CornerRadius="2" Margin="4" Padding="4,1">
                    <TextBlock x:Name="DurationText" Foreground="White" FontSize="10"/>
                </Border>

                <Border x:Name="RatingPanel" VerticalAlignment="Top" HorizontalAlignment="Left"
                        Background="#CC000000" CornerRadius="2" Margin="4" Padding="3,1"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" x:Name="StarPanel"/>
                </Border>

                <Border x:Name="CheckMark" VerticalAlignment="Top" HorizontalAlignment="Left"
                        Background="#007ACC" CornerRadius="10"
                        Width="22" Height="22" Margin="4" Visibility="Collapsed">
                    <TextBlock Text="✓" Foreground="White" FontSize="13" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <Border x:Name="PlayButton" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#CC000000" CornerRadius="20" Width="40" Height="40"
                        Visibility="Collapsed" Cursor="Hand" MouseLeftButtonUp="OnPlayButtonClick">
                    <TextBlock Text="▶" Foreground="White" FontSize="18"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="3,0,0,0"/>
                </Border>
            </Grid>
        </Border>
    </Border>
</UserControl>
