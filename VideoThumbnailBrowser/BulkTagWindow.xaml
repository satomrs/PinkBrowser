<Window x:Class="VideoThumbnailBrowser.BulkTagWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="タグを一括付与" Height="320" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#252526">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 件数表示 -->
        <TextBlock Grid.Row="0" x:Name="TargetCountText" Foreground="#AAAAFF"
                   FontWeight="Bold" Margin="0,0,0,12" />

        <!-- 新規タグ入力欄 -->
        <TextBlock Grid.Row="1" Text="新しいタグを入力（カンマ区切り）" Foreground="White" Margin="0,0,0,4" />
        <TextBox Grid.Row="2" x:Name="NewTagInput" Padding="6,4" Background="#3C3C3C"
                 Foreground="White" BorderBrush="#555" Margin="0,0,0,12" />

        <!-- 既存タグ一覧 -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="登録済みタグ（クリックで追加）" Foreground="Gray" Margin="0,0,0,4" />
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ExistingTagsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}" Margin="0,0,6,6" Padding="8,3"
                                    Background="#3C3C3C" Foreground="White"
                                    BorderBrush="#555" Click="OnTagButtonClick"
                                    Cursor="Hand" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- 選択済みタグ表示 -->
        <Border Grid.Row="4" Background="#1E1E1E" BorderBrush="#555" BorderThickness="1"
                Padding="6,4" Margin="0,8,0,0" Visibility="Collapsed" x:Name="SelectedTagsPanel">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="付与するタグ: " Foreground="Gray" VerticalAlignment="Center" />
                <TextBlock x:Name="SelectedTagsText" Foreground="#AAAAFF" VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="付与する" Width="90" Margin="0,0,8,0" Padding="4"
                    IsDefault="True" Click="OnApplyClick" />
            <Button Content="キャンセル" Width="90" Padding="4" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
